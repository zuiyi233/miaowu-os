# ===========================================
# AI 服务配置 - Mì Jìng Novelist AI
# ===========================================

# Google Gemini API Key (用于大纲生成、续写等核心功能)
API_KEY="AIza..."

# (可选) Gemini Flash 模型名称
# 如果不设置，将默认使用 gemini-2.5-flash
GEMINI_FLASH_MODEL="gemini-2.5-flash"

# (可选) New API / OpenAI 兼容网关配置 (用于润色、扩写、Embedding 等)
NEW_API_KEY="sk-..."
NEW_API_BASE_URL="https://api.newapi.ai/v1"
NEW_API_TEXT_MODEL="deepseek-chat"
NEW_API_EMBEDDING_MODEL="text-embedding-3-small"

# (可选) 如果 Embedding 地址不是 base_url/embeddings，则单独指定
# NEW_API_EMBEDDING_URL="https://..."